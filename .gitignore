# Jupyter
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Python bytecode
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Data — raw and processed files are not committed
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Models — saved artifacts are generated outputs
models/*.pkl
models/*.json

# Reports — figures are committed intentionally as a snapshot
# Uncomment below to exclude figures if preferred
# reports/figures/*
# !reports/figures/.gitkeep

# Environment
.env
.venv/
env/
venv/

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/